# ── Inference backend (set ONE of these) ──────────────────────────────────────
# Option A — Modal web endpoint (modal deploy modal_api.py, then paste the URL)
TRYON_ENDPOINT_URL=https://your-username--fashn-vton-api-vtonapi-fastapi-app.modal.run

# Option B — Replicate (requires billing)
REPLICATE_API_TOKEN=r8_your_token_here
REPLICATE_MODEL_VERSION=a10ae1ae726e5050a961e056e65cb84a576f308528c50993a6d3800d1a2ec162

# ── Nuvemshop app credentials ─────────────────────────────────────────────────
NUVEMSHOP_APP_ID=35464
NUVEMSHOP_CLIENT_SECRET=your_client_secret_here

# ── NubeSDK bundle (baked in at build time — set before npm run build) ────────
VITE_WIDGET_URL=https://your-app.railway.app
