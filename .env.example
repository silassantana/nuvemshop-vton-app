# Set these in Railway's environment variables panel — never commit real values
REPLICATE_API_TOKEN=r8_your_token_here
REPLICATE_MODEL_VERSION=a10ae1ae726e5050a961e056e65cb84a576f308528c50993a6d3800d1a2ec162

# Nuvemshop app credentials (for future OAuth/API calls)
NUVEMSHOP_APP_ID=35464
NUVEMSHOP_CLIENT_SECRET=your_client_secret_here

# Set this before building the NubeSDK bundle (VITE_ prefix = baked in at build time)
VITE_WIDGET_URL=https://your-app.railway.app
